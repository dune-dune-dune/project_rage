# Copy to .env and adjust. .env holds deployment/network/secrets (git-ignored).
# Control tuning (axis speeds, fire durations) lives in settings.toml instead.

# --- RWS network (turret) ---
RWS_SRC_IP=192.168.88.33
RWS_SRC_PORT=7770
RWS_DST_IP=192.168.88.56
RWS_DST_PORT=7780
# SAFETY: true = build/log packets but do NOT transmit to hardware. Keep true
# until you are deliberately driving authorized hardware on a Linux host.
RWS_DRY_RUN=true
# Empty = use the built-in 32-byte salt; or an absolute path to salt.bin.
RWS_SALT_FILE=

# --- Auth ---
# 7-digit PIN for the cockpit login. Empty = login disabled (open access).
COCKPIT_PIN=
# Session-signing secret. Set a stable random value so sessions survive restarts.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# --- Web / Gunicorn ---
WEB_BIND=0.0.0.0:8000
# MUST be 1: a single worker is the sole owner of the UDP socket and the
# command sequence counter. More workers => multiple senders => corrupt stream.
GUNICORN_WORKERS=1
GUNICORN_THREADS=8
LOG_LEVEL=info

# --- Video (WHEP from MediaMTX) ---
VIDEO_GATEWAY_HOST_IP=192.168.88.33
# Camera main streams are H265/HEVC. For cross-browser video use the H264
# transcoded path (cam95_h264 / cam96_h264). If you use Safari (or Chrome on an
# HEVC-capable Mac) you can point directly at cam95_main for lower latency.
WHEP_URL=http://192.168.88.33:8889/cam95_h264/whep
