# Copy to .env and adjust. .env holds deployment/network/secrets (git-ignored).
# Control tuning (axis speeds, fire durations) lives in settings.toml instead.

# --- RWS network (turret) ---
RWS_SRC_IP=192.168.88.33
RWS_SRC_PORT=7770
RWS_DST_IP=192.168.88.56
RWS_DST_PORT=7780
# SAFETY: true = build/log packets but do NOT transmit to hardware. Keep true
# until you are deliberately driving authorized hardware on a Linux host.
RWS_DRY_RUN=true
# Empty = use the built-in 32-byte salt; or an absolute path to salt.bin.
RWS_SALT_FILE=

# --- Rangefinder (Benewake TF03-180, serial). Production/Jetson only. ---
# Locally there is no rangefinder, so keep this false. On the Jetson it is set to
# true by docker-compose.jetson.yml (which also passes /dev/ttyUSB0 through).
RANGEFINDER_ENABLED=false
RANGEFINDER_PORT=/dev/ttyUSB0
RANGEFINDER_BAUD=115200

# --- Auth ---
# 7-digit PIN for the cockpit login. Empty = login disabled (open access).
COCKPIT_PIN=
# Session-signing secret. Set a stable random value so sessions survive restarts.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# --- Web / Gunicorn ---
WEB_BIND=0.0.0.0:8000
# MUST be 1: a single worker is the sole owner of the UDP socket and the
# command sequence counter. More workers => multiple senders => corrupt stream.
GUNICORN_WORKERS=1
GUNICORN_THREADS=8
LOG_LEVEL=info

# --- AI model library (⚙ -> «Налаштування ШІ моделі») ---
# Uploaded YOLO weights are converted to ONNX by the `exporter` container, which
# is the only place ultralytics/torch lives (a torch export must never run in the
# process that owns the 20 Hz turret loop). Defaults match docker-compose.yml —
# override only if you moved the sidecar.
# EXPORTER_URL=http://127.0.0.1:8901
# Where the exporter container sees the shared ./data bind mount.
# EXPORTER_DATA_DIR=/data
# Largest uploadable weights file, in MB (bigger => HTTP 413).
# MODEL_MAX_UPLOAD_MB=512

# --- Video (WHEP from MediaMTX) ---
# The video gateway address and the MediaMTX stream paths are NO LONGER set here.
# They are per-profile settings (local LAN / remote VPN) stored in SQLite
# (data/cockpit.db) and editable in the cockpit: ⚙ -> «Налаштування мережі».
# Defaults: services/web/app/migrations/0002_seed_network.sql.
#
# The only video knob left is the ICE hosts MediaMTX advertises. Both the LAN and
# the VPN address are advertised by default (see docker-compose.yml), so the
# local/remote switch works without restarting the container. Override only if
# your addresses differ:
# MEDIAMTX_HOSTS=192.168.88.33,10.20.100.1
